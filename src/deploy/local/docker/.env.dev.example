COMPOSE_PROJECT_NAME=simpletrack-local

SIMPLETRACK_POSTGRES_HOST_PORT=5432
SIMPLETRACK_MINIO_API_HOST_PORT=9000
SIMPLETRACK_MINIO_CONSOLE_HOST_PORT=9001
SIMPLETRACK_REDIS_HOST_PORT=26379
SIMPLETRACK_REDIS_INSIGHT_HOST_PORT=28001
SIMPLETRACK_MYSQL_HOST_PORT=23306
SIMPLETRACK_CLICKHOUSE_HTTP_HOST_PORT=28123
SIMPLETRACK_CLICKHOUSE_NATIVE_HOST_PORT=29000
SIMPLETRACK_KAFKA_HOST_PORT=29092

SIMPLETRACK_DOCS_HOST_PORT=3002
SIMPLETRACK_MARKETING_HOST_PORT=3004
SIMPLETRACK_SAAS_HOST_PORT=3005
SIMPLETRACK_ANALYTICS_SERVICE_HOST_PORT=8080

SIMPLETRACK_PUBLIC_DOCS_URL=http://localhost:3002
SIMPLETRACK_PUBLIC_MARKETING_URL=http://localhost:3004
SIMPLETRACK_PUBLIC_SAAS_URL=http://localhost:3005

SIMPLETRACK_RUNTIME_SOURCE_TOKEN=runtime-service-token
SIMPLETRACK_QUERY_TOKEN=query-service-token

SIMPLETRACK_POSTGRES_USER=postgres
SIMPLETRACK_POSTGRES_PASSWORD=postgres
SIMPLETRACK_POSTGRES_DB=simpletrack

SIMPLETRACK_MINIO_ROOT_USER=minioadmin
SIMPLETRACK_MINIO_ROOT_PASSWORD=minioadmin
SIMPLETRACK_AVATARS_BUCKET=avatars

SIMPLETRACK_ANALYTICS_MYSQL_DATABASE=analytics_core
SIMPLETRACK_ANALYTICS_MYSQL_USER=analytics_core
SIMPLETRACK_ANALYTICS_MYSQL_PASSWORD=analytics_core
SIMPLETRACK_ANALYTICS_MYSQL_ROOT_PASSWORD=analytics_core_root

SIMPLETRACK_ANALYTICS_CLICKHOUSE_DATABASE=analytics_core
SIMPLETRACK_ANALYTICS_CLICKHOUSE_USER=analytics_core
SIMPLETRACK_ANALYTICS_CLICKHOUSE_PASSWORD=analytics_core

SIMPLETRACK_KAFKA_IMAGE=bitnami/kafka:3.9

GOPROXY=https://proxy.golang.org,direct
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
